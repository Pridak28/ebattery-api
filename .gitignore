# ============================================================================
# battery-analytics-pro — root .gitignore
# Created by Master Setup Agent (Stage 1 of dual-agent system)
# ============================================================================

# ---- Secrets ----
.env
.env.*
!.env.example
secrets/
*.secret
*.pem
*.key
.envrc

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/

# ---- Python virtualenvs (in any folder, any depth) ----
venv/
.venv/
env/
.env-py/
backend/venv/
backend/.venv/
**/venv/
**/.venv/

# ---- Node / Next.js ----
node_modules/
**/node_modules/
node_modules_broken_*/
.next/
.next-build/
out/
out\ 2/
out\ 3/
.netlify/
.vercel/
.turbo/
dist/
build/

# ---- Frontend caches ----
*.tsbuildinfo
.eslintcache
.stylelintcache
.parcel-cache/

# ---- Package manager logs / lockfile noise ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/

# ---- macOS / Editor cruft ----
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
.cursor/

# ---- Local logs ----
*.log
logs/
local-logs/
backend/logs/
frontend/logs/

# ---- Agent scratch / temporary outputs (NOT the queue itself) ----
.agent-scratch/
.agent-temp/
**/.agent-tmp/
.local-agents-cache/

# ---- Loop runtime files we don't want committed ----
reports/local-agents/queue/claims/*.json
!reports/local-agents/queue/claims/.gitkeep
reports/local-agents/queue/exhausted/*.json
reports/local-agents/queue/results/*.json
!reports/local-agents/queue/results/.gitkeep
reports/local-agents/runs/
reports/local-agents/reports/master-refill/
caffeinate.pid
.run-id

# ---- Backup tarballs of git history ----
.agent-backups/

# ---- Claude Code internal session state ----
.claude/scheduled_tasks.lock
.claude/session-*.json

# ---- DAMAS / PZU heavy raw artifacts (keep canonical processed only) ----
backend/data/*.xlsx
backend/data\ 2/
backend/data/imbalance_history_estimated.csv
backend/data/imbalance_history_filtered.csv
backend/data/imbalance_history_original_backup.csv
backend/data/system_imbalance_awards.csv
backend/data/new_fetch_transelectrica/
backend/data/new_official_raw/
*.pre-2026-05-02-merge

# ---- Stale duplicate dirs flagged by cleanup audit ----
backend/venv/bin\ 2/
backend/venv/pyvenv\ 2.cfg
frontend/clean.py
frontend/force_clean.py
frontend/force_clean.sh
frontend/out\ 2/
frontend/out\ 3/

# ---- Sibling fresh-agents snapshot (not part of root) ----
# (this is a sibling folder anyway, not inside, but listed for safety)

# ---- Top-level Mobile docs (drift from a prior session) — keep in tree
# but don't auto-track new mobile_*.md unless you want them
# (Commenting this out so existing files commit; uncomment to ignore future)
# MOBILE_*.md
# BROWSER_*.md
